@{
    ViewData["Title"] = "Home Page";
}

<div class="hero-glass text-center mt-3">
    <div class="mb-4">
        <i class="bi bi-compass" style="font-size: 4rem; color: var(--travel-icon-dark);"></i>
    </div>
    
    <h1 class="display-3 fw-bold mb-3" style="color: var(--travel-primary);">
        Design Your Next <span style="color: var(--travel-accent);">Adventure</span>
    </h1>
    
    <p class="lead text-muted mb-5 mx-auto" style="max-width: 600px; font-weight: 300;">
        Escape the ordinary. Plan your trips, discover breathtaking destinations, manage accommodations, 
        and curate unforgettable experiences all in one beautifully unified space.
    </p>
    
    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a class="btn btn-travel btn-lg px-5 py-3" asp-controller="Trips" asp-action="Index">
            <i class="bi bi-journal-album me-2" style="color: white !important;"></i> View All Trips
        </a>
        <a class="btn btn-outline-travel btn-lg px-5 py-3" asp-controller="Destinations" asp-action="Index">
            Explore Destinations
        </a>
    </div>
</div>

<div class="row mt-5 text-center">
    <div class="col-md-4 mb-4">
        <a asp-controller="Trips" asp-action="Index" class="p-4 travel-card d-block text-decoration-none">
            <i class="bi bi-map text-primary" style="font-size: 3rem;"></i>
            <h3 class="mt-3 fw-bold border-0 text-dark">Plan Intuitively</h3>
            <p class="text-muted mb-0">Easily string together destinations, accommodations, and activities.</p>
        </a>
    </div>
    <div class="col-md-4 mb-4">
        <a asp-controller="Transports" asp-action="Index" class="p-4 travel-card d-block text-decoration-none">
            <i class="bi bi-geo-alt text-primary" style="font-size: 3rem;"></i>
            <h3 class="mt-3 fw-bold border-0 text-dark">Get Around</h3>
            <p class="text-muted mb-0">Browse and manage all of your travel arrangements.</p>
        </a>
    </div>
    <div class="col-md-4 mb-4">
        <a asp-controller="Reviews" asp-action="Index" class="p-4 travel-card d-block text-decoration-none">
            <i class="bi bi-star-fill text-primary" style="font-size: 3rem;"></i>
            <h3 class="mt-3 fw-bold border-0 text-dark">Review Experiences</h3>
            <p class="text-muted mb-0">Read and write reviews for the places you've visited.</p>
        </a>
    </div>
</div>
