@model projektLana.Trip
@using projektLana.Data
@{ 
    ViewData["Title"] = "Trip Details"; 

    // Aggregate everything into a timeline event list
    var events = new List<(DateTime Date, DateTime ExactTime, string Type, string Title, string Desc, string Icon, decimal Cost, string Controller, int Id)>();

    foreach(var dest in Model.Destinations) {
        // Activities
        foreach(var act in dest.Activities) {
            events.Add((act.Date.Date, act.Date, "Activity", act.Name, act.TypeOfActivity.ToString(), "bi-ticket-detailed-fill", act.Cost, "Activities", act.Id));
        }
        // Transports (Split into Departure and Arrival for accurate timeline)
        foreach(var trans in dest.Transports) {
            string transIcon = trans.Type switch {
                TransportType.Airplane => "bi-airplane-fill",
                TransportType.Bus => "bi-bus-front-fill",
                TransportType.Train => "bi-train-front-fill",
                TransportType.Car => "bi-car-front-fill",
                TransportType.Ferry => "bi-water",
                _ => "bi-send-fill"
            };
            events.Add((trans.DepartureTime.Date, trans.DepartureTime, "Transport", $"{trans.Type} Departure - {dest.City}", $"Departs at {trans.DepartureTime:HH:mm}", transIcon, trans.Cost, "Transports", trans.Id));
            events.Add((trans.ArrivalTime.Date, trans.ArrivalTime, "Transport", $"{trans.Type} Arrival - {dest.City}", $"Arrives at {trans.ArrivalTime:HH:mm}", transIcon, 0m, "Transports", trans.Id));
        }
        // Accommodations (Check-in and Check-out)
        foreach(var acc in dest.Accommodations) {
            events.Add((acc.CheckInDate.Date, acc.CheckInDate, "Stay Check-in", acc.Name, acc.Type.ToString(), "bi-door-open-fill", acc.CostPerNight, "Accommodations", acc.Id));
            events.Add((acc.CheckOutDate.Date, acc.CheckOutDate, "Stay Check-out", acc.Name, "Departure", "bi-door-closed-fill", 0m, "Accommodations", acc.Id));
        }
    }

    // Group by Day and order chronologically
    var groupedEvents = events.OrderBy(e => e.ExactTime).GroupBy(e => e.Date).ToList();

    // Fetch Reviews matching this trip's user and destinations
    var tripReviews = MockRepository.Reviews
        .Where(r => r.User?.Id == Model.User?.Id && Model.Destinations.Any(d => d.Id == r.Destination?.Id))
        .ToList();
}

<div class="container mt-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0 m-0 fs-5">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-muted text-decoration-none">Trips</a></li>
            <li class="breadcrumb-item active fw-bold" style="color: var(--travel-primary);" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <!-- Header Section -->
    <div class="travel-card card p-5 mb-5 border-0">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-4 fw-bold mb-3" style="color: var(--travel-dark);">@Model.Name</h1>
                <p class="lead text-muted mb-4">
                    <i class="bi bi-calendar-range me-2" style="color: var(--travel-icon-dark) !important;"></i>
                    @Model.StartDate.ToString("MMMM dd, yyyy") — @Model.EndDate.ToString("MMMM dd, yyyy")
                </p>
                <div class="d-flex align-items-center gap-3">
                    <span class="badge rounded-pill px-4 py-2 shadow-sm" style="background-color: var(--travel-primary); color: white;">
                        @Model.Destinations.Count Destinations
                    </span>
                    <span class="text-muted fw-bold">
                        <i class="bi bi-person-fill fs-5 me-1" style="color: var(--travel-secondary);"></i> @Model.User?.FirstName @Model.User?.LastName
                    </span>
                    <span class="badge rounded-pill px-4 py-2 shadow d-flex align-items-center text-white" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); font-size: 1.1rem; letter-spacing: 0.5px;">
                        <i class="bi bi-wallet2 fs-4 me-2" style="color: white !important;"></i> $@Model.TotalCost
                    </span>
                </div>
            </div>
            <div class="col-md-4 text-md-end mt-4 mt-md-0">
                <a asp-action="Index" class="btn btn-outline-travel btn-lg">
                    <i class="bi bi-arrow-left me-2"></i> Back to Trips
                </a>
            </div>
        </div>
    </div>

    <!-- Timeline Itinerary Section -->
    <div class="mb-5">
        <h2 class="fw-bold mb-4" style="color: var(--travel-primary);">Trip Itinerary</h2>
        
        @if (!groupedEvents.Any()) {
            <div class="alert text-center p-4 travel-card" style="background-color: var(--travel-light);">No itinerary events found.</div>
        } else {
            @foreach (var dayGroup in groupedEvents) {
                <div class="mb-5">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-white rounded-circle shadow-sm d-flex justify-content-center align-items-center me-3" style="width: 60px; height: 60px; border: 3px solid var(--travel-secondary);">
                            <span class="fw-bold fs-4" style="color: var(--travel-primary);">@dayGroup.Key.Day</span>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-0 text-dark">@dayGroup.Key.ToString("MMMM yyyy")</h4>
                            <span class="text-muted small text-uppercase fw-bold">@dayGroup.Key.ToString("dddd")</span>
                        </div>
                    </div>

                    <div class="ms-4 border-start border-2 ps-4" style="border-color: var(--travel-light) !important;">
                        <div class="row row-cols-1 g-3">
                            @foreach (var ev in dayGroup) {
                                <div class="col">
                                    <div class="travel-card card border-0 bg-white">
                                        <div class="card-body p-3 d-flex align-items-center justify-content-between">
                                            <div class="d-flex align-items-center">
                                                <div class="p-3 rounded-4 bg-light me-3 text-center">
                                                    <i class="bi @ev.Icon fs-3" style="color: var(--travel-icon-dark) !important;"></i>
                                                </div>
                                                <div>
                                                    <span class="badge mb-1" style="background-color: var(--travel-accent); color: white;">@ev.Type.ToUpper()</span>
                                                    <h5 class="fw-bold mb-1 text-dark">@ev.Title</h5>
                                                    <p class="text-muted mb-0 small">@ev.ExactTime.ToString("HH:mm") — @ev.Desc</p>
                                                </div>
                                            </div>
                                            <div class="text-end">
                                                @if(ev.Cost > 0) {
                                                    <h5 class="fw-bold mb-2" style="color: var(--travel-primary);">$@ev.Cost</h5>
                                                }
                                                <a asp-controller="@ev.Controller" asp-action="Details" asp-route-id="@ev.Id" class="btn btn-outline-travel btn-sm">Details</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Reviews Section -->
    <div class="mb-5 border-top pt-5">
        <h2 class="fw-bold mb-4" style="color: var(--travel-primary);">Destinations Reviews</h2>
        
        @if (!tripReviews.Any()) {
            <div class="alert text-center p-4 travel-card" style="background-color: var(--travel-light);">No reviews have been written for this trip's destinations by the user yet.</div>
        } else {
            <div class="row row-cols-1 row-cols-md-2 g-4">
                @foreach (var review in tripReviews) {
                    <div class="col">
                        <div class="travel-card card border-0 h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="fw-bold mb-0 text-dark">@review.Destination?.City</h5>
                                    <span class="badge rounded-pill text-white px-3 py-2 shadow-sm" style="background-color: var(--travel-accent);">
                                        @review.Rating / 5 <i class="bi bi-star-fill text-white ms-1" style="color: white !important;"></i>
                                    </span>
                                </div>
                                <p class="card-text text-muted" style="font-style: italic; font-size: 1.1rem;">"@review.Comment"</p>
                                <div class="text-muted small mt-3 border-top pt-3">
                                    <i class="bi bi-person-circle me-1" style="color: var(--travel-icon-dark) !important;"></i> 
                                    @review.User?.FirstName @review.User?.LastName
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>  