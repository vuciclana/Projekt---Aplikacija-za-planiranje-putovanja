@model IEnumerable<projektLana.Trip>

@{
    ViewData["Title"] = "All Trips";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h1 class="display-5 fw-bold" style="color: var(--travel-primary);">Travel Experiences</h1>
            <p class="text-muted lead">Manage and plan your global adventures.</p>
        </div>
    </div>

    @if (!Model.Any()) {
        <div class="alert text-center p-5 travel-card" style="background-color: var(--travel-light);">
            <i class="bi bi-compass display-1" style="color: var(--travel-primary);"></i>
            <h3 class="mt-3 text-dark">No trips planned yet</h3>
            <p class="text-muted">Start your journey by creating a new trip.</p>
        </div>
    } else {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model) {
                <div class="col">
                    <div class="travel-card card">
                        <div class="card-body">
                            <h4 class="card-title fw-bold">@item.Name</h4>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-calendar-range" style="color: var(--travel-icon-dark);"></i> 
                                @item.StartDate.ToString("MMM dd, yyyy") - @item.EndDate.ToString("MMM dd, yyyy")
                            </p>
                            <span class="badge-travel">@item.Destinations.Count Destinations</span>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 pb-3 text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-travel btn-sm">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>