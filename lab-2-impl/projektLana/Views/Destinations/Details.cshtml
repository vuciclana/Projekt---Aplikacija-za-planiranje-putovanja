@model projektLana.Destination
@{ ViewData["Title"] = "Destination Details"; }

<div class="container mt-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0 m-0 fs-5">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-muted text-decoration-none">Destinations</a></li>
            <li class="breadcrumb-item active fw-bold" style="color: var(--travel-primary);" aria-current="page">@Model.City</li>
        </ol>
    </nav>

    <div class="travel-card card p-5 mb-4 border-0">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h1 class="display-4 fw-bold text-dark mb-2">@Model.City</h1>
                <h3 class="mb-4" style="color: var(--travel-accent);">
                    <i class="bi bi-geo-alt-fill" style="color: var(--travel-icon-dark) !important;"></i> @Model.Country
                </h3>
                <p class="lead text-muted" style="max-width: 800px;">@Model.Description</p>
            </div>
        </div>
        <hr class="my-4 text-muted" />
        <div class="row text-center g-3">
            <div class="col-md-4">
                <div class="p-3 bg-light rounded-4">
                    <h4 style="color: var(--travel-primary);"><i class="bi bi-bicycle me-2"></i> @Model.Activities.Count</h4>
                    <span class="text-muted small fw-bold text-uppercase">Activities</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 bg-light rounded-4">
                    <h4 style="color: var(--travel-primary);"><i class="bi bi-house-door me-2"></i> @Model.Accommodations.Count</h4>
                    <span class="text-muted small fw-bold text-uppercase">Accommodations</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 bg-light rounded-4">
                    <h4 style="color: var(--travel-primary);"><i class="bi bi-send-fill me-2"></i> @Model.Transports.Count</h4>
                    <span class="text-muted small fw-bold text-uppercase">Transports</span>
                </div>
            </div>
        </div>
        <div class="mt-4 text-center">
            <a asp-action="Index" class="btn btn-outline-travel">Back to Destinations</a>
        </div>
    </div>
</div>