@model projektLana.Accommodation
@{ ViewData["Title"] = "Stay Details"; }

<div class="container mt-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0 m-0 fs-5">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-muted text-decoration-none">Stays</a></li>
            <li class="breadcrumb-item active fw-bold" style="color: var(--travel-primary);" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="travel-card card p-5 border-0 text-center">
        <span class="badge rounded-pill mx-auto mb-3 px-4 py-2 text-white fs-6 shadow-sm" style="background-color: var(--travel-secondary); width: fit-content;">@Model.Type</span>
        <h1 class="display-5 fw-bold text-dark mb-3">@Model.Name</h1>
        <p class="text-muted fs-5 mb-4"><i class="bi bi-pin-map-fill" style="color: var(--travel-icon-dark) !important;"></i> @Model.Address</p>
        
        <div class="d-inline-flex bg-light p-4 rounded-4 gap-5 justify-content-center mb-5 align-items-center border">
            <div>
                <small class="text-muted d-block fw-bold mb-1">Check In</small>
                <span class="fs-5 text-dark">@Model.CheckInDate.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="vr"></div>
            <div>
                <small class="text-muted d-block fw-bold mb-1">Check Out</small>
                <span class="fs-5 text-dark">@Model.CheckOutDate.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="vr"></div>
            <div>
                <small class="text-muted d-block fw-bold mb-1">Cost / Night</small>
                <span class="fs-3 fw-bold" style="color: var(--travel-primary);">$@Model.CostPerNight</span>
            </div>
        </div>
        
        <div>
            <a asp-action="Index" class="btn btn-outline-travel mt-2">Back to List</a>
        </div>
    </div>
</div>