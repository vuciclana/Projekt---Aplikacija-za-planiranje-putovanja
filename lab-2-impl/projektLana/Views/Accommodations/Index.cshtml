@model IEnumerable<projektLana.Accommodation>
@{ ViewData["Title"] = "Accommodations"; }

<div class="container mt-4">
    <div class="mb-4 pb-2 border-bottom">
        <h1 class="display-5 fw-bold" style="color: var(--travel-primary);">Places to Stay</h1>
        <p class="text-muted lead">Browse beautiful hotels and apartments.</p>
    </div>

    @if (!Model.Any()) {
        <div class="alert text-center p-4 travel-card" style="background-color: var(--travel-light);">No accommodations added.</div>
    } else {
        var groupedAccommodations = Model.GroupBy(a => a.Type).OrderBy(g => g.Key);

        foreach (var grupa in groupedAccommodations)
        {
            <div class="mt-5 mb-3">
                <h3 class="fw-bold" style="color: var(--travel-dark);">
                    <i class="bi bi-buildings-fill me-2" style="color: var(--travel-icon-dark) !important;"></i> @grupa.Key Options
                </h3>
                <hr class="text-muted" />
            </div>

            <div class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var item in grupa.OrderBy(a => a.CostPerNight)) {
                    <div class="col">
                        <div class="travel-card card">
                            <div class="card-body">
                                <h5 class="card-title fw-bold mt-2 text-dark">@item.Name</h5>
                                <p class="text-muted small"><i class="bi bi-pin-map-fill" style="color: var(--travel-icon-dark);"></i> @item.Address</p>
                                <hr class="text-muted" />
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div>
                                        <small class="text-muted fw-bold d-block">Cost / Night</small>
                                        <strong class="fs-4" style="color: var(--travel-primary);">$@item.CostPerNight</strong>
                                    </div>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-travel btn-sm">View Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>