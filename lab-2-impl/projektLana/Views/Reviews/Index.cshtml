@model IEnumerable<projektLana.Review>
@{ ViewData["Title"] = "Reviews"; }

<div class="container mt-4">
    <div class="mb-4 pb-2 border-bottom">
        <h1 class="display-5 fw-bold" style="color: var(--travel-primary);">Traveler Reviews</h1>
        <p class="text-muted lead">See what others are saying about their experiences.</p>
    </div>

    @if (!Model.Any()) {
        <div class="alert text-center p-4 travel-card" style="background-color: var(--travel-light);">No reviews yet.</div>
    } else {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var item in Model) {
                <div class="col">
                    <div class="travel-card card border-0">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="fw-bold mb-0 text-dark">@item.Destination?.City</h5>
                                <span class="badge rounded-pill text-white px-3 py-2 shadow-sm" style="background-color: var(--travel-accent);">
                                    @item.Rating / 5 <i class="bi bi-star-fill ms-1" style="color: #F3CD61 !important;"></i>
                                </span>
                            </div>
                            <p class="card-text text-muted" style="font-style: italic; font-size: 1.1rem;">"@item.Comment"</p>
                            <div class="d-flex align-items-center mt-4 pt-3 border-top">
                                <i class="bi bi-person-circle fs-4 me-2" style="color: var(--travel-icon-dark);"></i>
                                <span class="fw-bold text-dark">@item.User?.FirstName @item.User?.LastName</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>