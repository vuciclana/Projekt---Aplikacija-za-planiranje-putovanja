@model IEnumerable<projektLana.Review>
@{ 
    ViewData["Title"] = "Reviews";
    string currentFilter = ViewData["CurrentFilter"]?.ToString() ?? "All";
}

<div class="container mt-4">
    <div class="mb-4 pb-2 border-bottom">
        <h1 class="display-5 fw-bold" style="color: var(--travel-primary);">Traveler Reviews</h1>
        <p class="text-muted lead">See what others are saying about their experiences.</p>
    </div>

    <!-- Filter Tabs -->
    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <a asp-action="Index" 
               class="nav-link @(currentFilter == "All" ? "active" : "")" 
               role="tab">
                <i class="bi bi-collection me-2"></i> All Reviews
            </a>
        </li>
        <li class="nav-item" role="presentation">
            <a asp-action="Recommended" 
               class="nav-link @(currentFilter == "Recommended" ? "active" : "")" 
               role="tab">
                <i class="bi bi-hand-thumbs-up-fill me-2" style="color: #28a745;"></i> Recommended
            </a>
        </li>
        <li class="nav-item" role="presentation">
            <a asp-action="NeedsImprovements" 
               class="nav-link @(currentFilter == "NeedsImprovements" ? "active" : "")" 
               role="tab">
                <i class="bi bi-hand-thumbs-down-fill me-2" style="color: #dc3545;"></i> Needs Improvement
            </a>
        </li>
    </ul>

    @if (!Model.Any()) {
        <div class="alert text-center p-4 travel-card" style="background-color: var(--travel-light);">No reviews yet.</div>
    } else {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var item in Model) {
                <div class="col">
                    <div class="travel-card card border-0 h-100 d-flex flex-column">
                        <div class="card-body p-4 flex-grow-1">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h5 class="fw-bold mb-1 text-dark">@(item.Destination?.City ?? "Unknown")</h5>
                                    <small class="text-muted"><i class="bi bi-person-fill me-1"></i>@item.ReviewerName</small>
                                </div>
                                <span class="badge rounded-pill text-white px-3 py-2 shadow-sm" style="background-color: var(--travel-accent); font-size: 1rem;">
                                    @item.Rating / 5 <i class="bi bi-star-fill text-white ms-1" style="color: white !important;"></i>
                                </span>
                            </div>
                            
                            <div class="mt-3 pt-3">
                                @if (item.IsPositive)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2"><i class="bi bi-hand-thumbs-up-fill me-1"></i> Recommended</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2"><i class="bi bi-hand-thumbs-down-fill me-1"></i> Needs Improvement</span>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top p-4 text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-travel btn-sm">Read Full Review</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>