@model projektLana.Transport
@{ ViewData["Title"] = "Travel Ticket"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="travel-card card p-0 border-0 overflow-hidden shadow">
            
            <div class="bg-dark text-white p-4 d-flex justify-content-between align-items-center">
                <h4 class="m-0 fw-bold"><i class="bi bi-ticket-detailed me-2"></i>Boarding Pass</h4>
                <div class="text-end">
                    <span class="badge bg-primary fs-6">@Model.Type</span>
                    @if (Model.IsLongTrip) {
                        <span class="badge bg-warning text-dark ms-2"><i class="bi bi-exclamation-triangle-fill"></i> Long Trip</span>
                    }
                </div>
            </div>

            <div class="p-5 text-center">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-4 border-bottom dashed">
                    <div class="text-center">
                        <small class="d-block text-muted text-uppercase fw-bold">Departure</small>
                        <h2 class="fw-bold m-0">@Model.DepartureTime.ToString("HH:mm")</h2>
                    </div>
                    
                    <div class="flex-grow-1 px-4 text-muted">
                        <small class="fw-bold">@Model.Duration.ToString(@"hh\h\ mm\m")</small>
                        <hr class="border-2 my-1" />
                    </div>

                    <div class="text-center">
                        <small class="d-block text-muted text-uppercase fw-bold">Arrival</small>
                        <h2 class="fw-bold m-0">@Model.ArrivalTime.ToString("HH:mm")</h2>
                    </div>
                </div>

                <div class="bg-light p-3 rounded">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong class="text-muted">Route Time:</strong>
                        <span>@Model.RouteTime</span>
                    </div>
                    <hr class="my-2" />
                    <div class="d-flex justify-content-between align-items-center">
                        <strong class="text-muted">Ticket Cost:</strong>
                        <span class="fw-bold fs-4 text-success">$@Model.Cost</span>
                    </div>
                </div>

                <a asp-action="Index" class="btn btn-outline-travel mt-4 w-100">Back Options</a>
            </div>
        </div>
    </div>
</div>