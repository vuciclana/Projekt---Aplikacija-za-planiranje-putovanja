@model IEnumerable<projektLana.Activity>
@using System.Globalization;
@using System.Text.RegularExpressions;
@{
    var culture = CultureInfo.CurrentCulture;
    string GenerateSlug(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        var slug = Regex.Replace(text.ToLower(), @"[^a-z0-9\s-]", "");
        slug = Regex.Replace(slug, @"\s+", "-");
        return Regex.Replace(slug, @"-+", "-").Trim('-');
    }
}

@if (!Model.Any()) {
    <div class="alert text-center p-4 travel-card" style="background-color: var(--travel-light);">No activities listed.</div>
} else {
    var groupedActivities = Model.GroupBy(a => a.TypeOfActivity).OrderBy(g => g.Key);

    foreach (var grupa in groupedActivities)
    {
        <div class="mt-5 mb-3">
            @{
                string iconClass = grupa.Key switch
                {
                    ActivityType.Sightseeing => "bi bi-camera-fill",
                    ActivityType.Food => "bi bi-cup-hot-fill",
                    ActivityType.Relaxation => "bi bi-bank2",
                    ActivityType.Party => "bi bi-music-note-beamed",
                    _=> "bi bi-collection-fill"
                };
            }

            <h3 class="fw-bold" style="color: var(--travel-dark);">
                <i class="@iconClass me-2" style="color: var(--travel-icon-dark) !important;"></i> @grupa.Key
            </h3>
            <hr class="text-muted" />
        </div>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in grupa) {
                <div class="col">
                    <div class="travel-card card">
                        <div class="card-body">
                            <h5 class="card-title fw-bold mt-2 text-dark">@item.Name</h5>
                            <p class="text-muted mt-2 mb-1"><i class="bi bi-calendar-event" style="color: var(--travel-icon-dark);"></i> @item.Date.ToString("d MMM yyyy", culture)</p>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <h4 class="mb-0" style="color: var(--travel-accent);">
                                    @(item.Cost > 0 ? $"${item.Cost}" : "Free")
                                </h4>
                                <a asp-action="Details" asp-route-activityType="@item.TypeOfActivity.ToString()" asp-route-activityName="@GenerateSlug(item.Name)" class="btn btn-outline-travel btn-sm">View Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
