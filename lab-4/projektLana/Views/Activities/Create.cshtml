@model projektLana.ActivityFormModel
@{
    ViewData["Title"] = "Create Activity";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0 m-0 fs-5">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-muted text-decoration-none">Activities</a></li>
            <li class="breadcrumb-item active fw-bold" style="color: var(--travel-primary);" aria-current="page">Create Activity</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="travel-card card border-0 p-0 overflow-hidden">
                <div class="p-5" style="background: linear-gradient(135deg, var(--travel-primary), var(--travel-secondary)); color: white;">
                    <h2 class="fw-bold mb-2"><i class="bi bi-ticket-detailed-fill me-3"></i>Add Activity</h2>
                    <p class="mb-0 opacity-90">Plan a new activity for a destination.</p>
                </div>
                <div class="p-5">
                      <form asp-action="Create" method="post" id="createActivityForm"
                          data-trip-range="true"
                          data-trip-range-url="@Url.Action("TripRange", "Destinations")"
                          data-trip-range-inputs="Date">
                        @Html.AntiForgeryToken()

                        <div class="mb-5 position-relative user-autocomplete" data-autocomplete-url="@Url.Action("Destinations", "Activities")">
                            <label asp-for="DestinationId" class="form-label fw-bold" style="color: var(--travel-dark);">Destination</label>
                            <input
                                type="text"
                                class="form-control form-control-lg user-autocomplete-input"
                                placeholder="Start typing a destination..."
                                autocomplete="off"
                                value="@Model.DestinationDisplayName" />
                            <input asp-for="DestinationId" type="hidden" class="user-autocomplete-value" />
                            <div class="list-group user-autocomplete-results"></div>
                            <span asp-validation-for="DestinationId" class="text-danger small mt-2 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TypeOfActivity" class="form-label fw-bold" style="color: var(--travel-dark);">Activity Type</label>
                            <select asp-for="TypeOfActivity" asp-items="Html.GetEnumSelectList<ActivityType>()" class="form-select form-select-lg">
                                <option value="">-- Select type --</option>
                            </select>
                            <span asp-validation-for="TypeOfActivity" class="text-danger small mt-2 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold" style="color: var(--travel-dark);">Name</label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="e.g., City walking tour" />
                            <span asp-validation-for="Name" class="text-danger small mt-2 d-block"></span>
                        </div>

                        @{
                            var dateModel = new projektLana.Models.DateTimePickerModel
                            {
                                FieldName = nameof(Model.Date),
                                FieldLabel = "Date",
                                FieldValue = Model.Date.HasValue ? Model.Date.Value.ToString("yyyy-MM-dd HH:mm") : ""
                            };
                        }
                        <partial name="_DateTimePickerPartial" model="dateModel" />
                        <span asp-validation-for="Date" class="text-danger small mt-2 d-block"></span>

                        <div class="mb-4">
                            <label asp-for="Cost" class="form-label fw-bold" style="color: var(--travel-dark);">Cost</label>
                            <input asp-for="Cost" class="form-control form-control-lg" />
                            <span asp-validation-for="Cost" class="text-danger small mt-2 d-block"></span>
                        </div>

                        <div class="d-flex gap-3 justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-lg" style="background: var(--travel-primary); color: white; border: none;">
                                <i class="bi bi-check-circle-fill me-2"></i>Create Activity
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const form = document.getElementById('createActivityForm');
            if ($(form).data('validator')) {
                $(form).data('validator').settings.ignore = '';
            }
        });
    </script>
}
