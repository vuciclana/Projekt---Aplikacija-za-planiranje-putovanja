@model IEnumerable<projektLana.Review>
@{ 
    ViewData["Title"] = "Reviews";
    string currentFilter = ViewData["CurrentFilter"]?.ToString() ?? "All";
}

<div class="container mt-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center mb-4 pb-3 border-bottom gap-3">
        <div>
            <h1 class="display-5 fw-bold" style="color: var(--travel-primary);">Traveler Reviews</h1>
            <p class="text-muted lead">See what others are saying about their experiences.</p>
        </div>
        <div class="d-flex flex-column flex-md-row gap-3 align-items-stretch">
            <div class="input-group input-group-sm" style="min-width: 280px;">
                <span class="input-group-text bg-white border-end-0 rounded-pill-start" style="border-color: var(--travel-primary);">
                    <i class="bi bi-search" style="color: var(--travel-primary);"></i>
                </span>
                <input
                    type="text"
                    class="form-control border-start-0 rounded-pill-end"
                    placeholder="Search reviews..."
                    autocomplete="off"
                    data-ajax-search="true"
                    data-search-url="@Url.RouteUrl("ReviewsSearch", new { filter = currentFilter })"
                    data-search-target="#reviewCardsContainer"
                    style="border-color: var(--travel-primary);" />
            </div>
            <a asp-action="Create" class="btn btn-travel btn-sm d-inline-flex align-items-center text-nowrap" style="padding: 0.6rem 1.4rem;">
                <i class="bi bi-plus-circle-fill me-2"></i>Create Review
            </a>
        </div>
    </div>

    <!-- Filter Tabs -->
    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <a asp-action="Index" 
               class="nav-link @(currentFilter == "All" ? "active" : "")" 
               role="tab">
                <i class="bi bi-collection me-2"></i> All Reviews
            </a>
        </li>
        <li class="nav-item" role="presentation">
            <a asp-action="Recommended" 
               class="nav-link @(currentFilter == "Recommended" ? "active" : "")" 
               role="tab">
                <i class="bi bi-hand-thumbs-up-fill me-2" style="color: #28a745;"></i> Recommended
            </a>
        </li>
        <li class="nav-item" role="presentation">
            <a asp-action="NeedsImprovements" 
               class="nav-link @(currentFilter == "NeedsImprovements" ? "active" : "")" 
               role="tab">
                <i class="bi bi-hand-thumbs-down-fill me-2" style="color: #dc3545;"></i> Needs Improvement
            </a>
        </li>
    </ul>

    <div id="reviewCardsContainer">
        <partial name="_ReviewCardsPartial" model="Model" />
    </div>
</div>