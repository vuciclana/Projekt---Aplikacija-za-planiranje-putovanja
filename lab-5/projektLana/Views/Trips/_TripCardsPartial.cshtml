@model IEnumerable<projektLana.Trip>
@using System.Text.RegularExpressions;

@{
    string GenerateSlug(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        var slug = Regex.Replace(text.ToLower(), @"[^a-z0-9\s-]", "");
        slug = Regex.Replace(slug, @"\s+", "-");
        return Regex.Replace(slug, @"-+", "-").Trim('-');
    }
}

@if (!Model.Any()) {
    <div class="alert text-center p-5 travel-card" style="background-color: var(--travel-light);">
        <i class="bi bi-compass display-1" style="color: var(--travel-primary);"></i>
        <h3 class="mt-3 text-dark">No trips planned yet</h3>
        <p class="text-muted">Start your journey by creating a new trip.</p>
        <a asp-action="Create" class="btn btn-lg mt-3" style="background: var(--travel-primary); color: white; border: none;">
            <i class="bi bi-plus-circle-fill me-2"></i>Create Your First Trip
        </a>
    </div>
} else {
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model) {
            <div class="col">
                <div class="travel-card card">
                    <div class="card-body">
                        <h4 class="card-title fw-bold">@item.Name</h4>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-calendar-range" style="color: var(--travel-icon-dark);"></i> 
                            @item.StartDate.ToString("dd MMM, yyyy") - @item.EndDate.ToString("dd MMM, yyyy")
                        </p>
                        <span class="badge-travel">@item.Destinations.Count Destinations</span>
                        @if (!string.IsNullOrEmpty(item.User?.FirstName))
                        {
                            <p class="text-muted small mt-3 mb-0">
                                <i class="bi bi-person-fill me-1" style="color: var(--travel-secondary);"></i>
                                @item.User.FirstName @item.User.LastName
                            </p>
                        }
                    </div>
                    <div class="card-footer bg-transparent border-top-0 pb-3 text-end">
                        <a asp-action="Details" asp-route-slug="@GenerateSlug(item.Name)" class="btn btn-outline-travel btn-sm">
                            <i class="bi bi-eye me-1"></i>View
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
