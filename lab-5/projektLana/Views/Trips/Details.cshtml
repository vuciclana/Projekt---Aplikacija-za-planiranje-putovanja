@model projektLana.Trip
@inject projektLana.Data.AppDbContext Db
@using Microsoft.EntityFrameworkCore
@using projektLana.Data
@using System.Linq
@using System.Text.RegularExpressions
@{
    ViewData["Title"] = "Trip Details";
    var tripReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    string GenerateSlug(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;
        var slug = Regex.Replace(text.ToLower(), @"[^a-z0-9\s-]", string.Empty);
        slug = Regex.Replace(slug, @"\s+", "-");
        return Regex.Replace(slug, @"-+", "-").Trim('-');
    }

    (DateTime? Start, DateTime? End) GetDestinationDateRange(Destination destination)
    {
        var accommodations = destination.Accommodations.Where(item => !item.IsDeleted).OrderBy(item => item.CheckInDate).ToList();
        if (accommodations.Any())
        {
            return (accommodations.First().CheckInDate, accommodations.Last().CheckOutDate);
        }

        var transports = destination.Transports.Where(item => !item.IsDeleted).OrderBy(item => item.DepartureTime).ToList();
        if (transports.Any())
        {
            return (transports.First().DepartureTime, transports.Last().ArrivalTime);
        }

        var activities = destination.Activities.Where(item => !item.IsDeleted).OrderBy(item => item.Date).ToList();
        if (activities.Any())
        {
            return (activities.First().Date, activities.Last().Date);
        }

        return (null, null);
    }

    string? GetDateLabel(Destination destination)
    {
        var range = GetDestinationDateRange(destination);
        if (!range.Start.HasValue || !range.End.HasValue)
        {
            return null;
        }

        if (range.Start.Value.Date == range.End.Value.Date)
        {
            return range.Start.Value.ToString("dd MMM, yyyy");
        }

        return $"{range.Start.Value:dd MMM, yyyy} - {range.End.Value:dd MMM, yyyy}";
    }

    var visibleDestinations = Model.Destinations
        .Where(destination => !destination.IsDeleted)
        .OrderBy(destination => GetDestinationDateRange(destination).Start ?? DateTime.MaxValue)
        .ThenBy(destination => destination.City)
        .ThenBy(destination => destination.Country)
        .ToList();

    var visibleDestinationIds = visibleDestinations.Select(destination => destination.Id).ToList();

    var itineraryCount = visibleDestinations.Count;
    var activityCount = visibleDestinations.Sum(destination => destination.Activities.Count(activity => !activity.IsDeleted));
    var accommodationCount = visibleDestinations.Sum(destination => destination.Accommodations.Count(accommodation => !accommodation.IsDeleted));
    var transportCount = visibleDestinations.Sum(destination => destination.Transports.Count(transport => !transport.IsDeleted));
    var reviewCount = Db.Reviews.Count(review => !review.IsDeleted && visibleDestinationIds.Contains(review.DestinationId));
    var totalBudget = Model.TotalCost;
}

<div class="container py-4 py-lg-5">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0 m-0 fs-5">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-muted text-decoration-none">Trips</a></li>
            <li class="breadcrumb-item active fw-bold" style="color: var(--travel-primary);" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="travel-card card border-0 shadow-sm mb-4">
        <div class="card-body p-4 p-lg-5">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <h1 class="display-4 fw-bold mb-3" style="color: var(--travel-dark);">@Model.Name</h1>
                    <div class="d-flex flex-wrap align-items-center gap-3 mb-4">
                        <span class="text-muted fw-semibold d-inline-flex align-items-center">
                            <i class="bi bi-calendar-range me-2" style="color: var(--travel-icon-dark) !important;"></i>
                            @Model.StartDate.ToString("dd MMMM, yyyy") - @Model.EndDate.ToString("dd MMMM, yyyy")
                        </span>
                        <span class="badge rounded-pill px-3 py-2" style="background-color: #0d6efd; color: white;">@itineraryCount Destinations</span>
                        <span class="text-muted fw-semibold d-inline-flex align-items-center">
                            <i class="bi bi-person-fill me-2" style="color: #d63384;"></i>
                            @Model.User?.FirstName @Model.User?.LastName
                        </span>
                        <span class="badge rounded-pill px-3 py-2 shadow-sm d-inline-flex align-items-center text-white" style="background: linear-gradient(135deg, #1db954 0%, #25c06d 100%);">
                            <i class="bi bi-wallet2 me-2"></i> $@totalBudget
                        </span>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap gap-2 justify-content-lg-end">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg d-inline-flex align-items-center px-4">
                            <i class="bi bi-pencil me-2"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-lg d-inline-flex align-items-center px-4">
                            <i class="bi bi-trash me-2"></i> Delete
                        </a>
                        <a asp-action="Index" class="btn btn-outline-info btn-lg d-inline-flex align-items-center px-4">
                            <i class="bi bi-arrow-left me-2"></i> Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="travel-card card border-0 shadow-sm mb-4">
        <div class="card-body p-4 p-lg-5">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                <div>
                    <h2 class="h3 fw-bold mb-1" style="color: var(--travel-dark);">Itinerary</h2>
                    <p class="text-muted mb-0">Destinations are ordered by the first planned date in each destination.</p>
                </div>
                @if (visibleDestinations.Any())
                {
                    <a asp-controller="Destinations" asp-action="Create" asp-route-tripId="@Model.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-primary btn-lg d-inline-flex align-items-center px-4">
                        <i class="bi bi-plus-lg me-2"></i> Add Destination
                    </a>
                }
            </div>

            @if (!visibleDestinations.Any())
            {
                <div class="border rounded-4 p-5 text-center bg-light-subtle">
                    <div class="mb-3">
                        <i class="bi bi-map display-3" style="color: #0d6efd;"></i>
                    </div>
                    <h3 class="fw-bold mb-2" style="color: var(--travel-dark);">@Model.Name</h3>
                    <p class="text-muted mb-4">This trip is still empty.</p>
                    <a asp-controller="Destinations" asp-action="Create" asp-route-tripId="@Model.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-primary btn-lg px-4">
                        <i class="bi bi-plus-lg me-2"></i> Add Destination
                    </a>
                </div>
            }
            else
            {
                <div class="vstack gap-4">
                    @foreach (var destination in visibleDestinations)
                    {
                        var destinationActivities = destination.Activities.Where(activity => !activity.IsDeleted).OrderBy(activity => activity.Date).ToList();
                        var destinationAccommodations = destination.Accommodations.Where(accommodation => !accommodation.IsDeleted).OrderBy(accommodation => accommodation.CheckInDate).ToList();
                        var destinationTransports = destination.Transports.Where(transport => !transport.IsDeleted).OrderBy(transport => transport.DepartureTime).ToList();
                        var destinationReviews = Db.Reviews.Where(review => !review.IsDeleted && review.DestinationId == destination.Id).OrderByDescending(review => review.Id).ToList();
                        var dateLabel = GetDateLabel(destination);

                        <div class="card border-0 shadow-sm overflow-hidden">
                            <div class="card-header bg-white border-0 p-0">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 px-4 py-4 border-bottom">
                                    <div>
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <span class="text-danger"><i class="bi bi-geo-alt-fill"></i></span>
                                            <h3 class="h4 fw-bold mb-0 text-dark">@destination.City</h3>
                                        </div>
                                        <div class="text-muted small">@destination.Country</div>
                                    </div>
                                    <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-3">
                                        @if (!string.IsNullOrWhiteSpace(dateLabel))
                                        {
                                            <div class="text-muted small d-inline-flex align-items-center gap-2 text-md-end">
                                                <i class="bi bi-calendar3"></i>
                                                @dateLabel
                                            </div>
                                        }
                                        <a asp-controller="Destinations" asp-action="Details" asp-route-country="@destination.Country" asp-route-city="@destination.City" asp-route-returnUrl="@tripReturnUrl" class="btn btn-outline-travel btn-sm itinerary-destination-view">
                                            <i class="bi bi-eye me-2"></i> View Destination
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="card-body p-4 p-lg-5 bg-light-subtle">
                                <div class="row g-4 row-cols-1 row-cols-lg-2 row-cols-xxl-4">
                                    <div class="col">
                                        <div class="h-100 border rounded-4 p-4 bg-white">
                                            <div class="d-flex align-items-center justify-content-between mb-3">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="bi bi-ticket-detailed-fill text-danger fs-5"></i>
                                                    <h4 class="h6 fw-bold mb-0 text-dark">Activities</h4>
                                                </div>
                                                <span class="badge rounded-pill text-bg-light">@destinationActivities.Count</span>
                                            </div>

                                            @if (!destinationActivities.Any())
                                            {
                                                <div class="text-center py-4">
                                                    <p class="text-muted mb-3">No activities planned yet.</p>
                                                    <a asp-controller="Activities" asp-action="Create" asp-route-destinationId="@destination.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-primary btn-sm px-4">
                                                        <i class="bi bi-plus-lg me-2"></i> Add Activity
                                                    </a>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="vstack gap-2">
                                                    @foreach (var activity in destinationActivities.Take(3))
                                                    {
                                                        <div class="border rounded-4 p-3 bg-white itinerary-item-card">
                                                            <div class="d-flex flex-column h-100">
                                                                <div class="flex-grow-1">
                                                                    <div class="fw-semibold text-dark">@activity.Name</div>
                                                                    <div class="text-muted small">@activity.TypeOfActivity • @activity.Date.ToString("dd MMM, HH:mm")</div>
                                                                </div>
                                                                <div class="itinerary-item-actions">
                                                                    <a asp-controller="Activities" asp-action="Details" asp-route-activityType="@activity.TypeOfActivity.ToString()" asp-route-activityName="@GenerateSlug(activity.Name)" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm itinerary-view-btn" title="View Activity" aria-label="View Activity">
                                                                        <i class="bi bi-eye"></i>
                                                                    </a>
                                                                    <a asp-controller="Activities" asp-action="Edit" asp-route-id="@activity.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm btn-outline-warning" title="Edit Activity">
                                                                        <i class="bi bi-pencil"></i>
                                                                    </a>
                                                                    <a asp-controller="Activities" asp-action="Delete" asp-route-id="@activity.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm btn-outline-danger" title="Delete Activity">
                                                                        <i class="bi bi-trash"></i>
                                                                    </a>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (destinationActivities.Count > 3)
                                                    {
                                                        <div class="text-muted small text-center">+ @(destinationActivities.Count - 3) more</div>
                                                    }
                                                </div>
                                                <div class="pt-3 mt-3 border-top text-end">
                                                    <a asp-controller="Activities" asp-action="Create" asp-route-destinationId="@destination.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-primary btn-sm px-4">
                                                        <i class="bi bi-plus-lg me-2"></i> Add Activity
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <div class="col">
                                        <div class="h-100 border rounded-4 p-4 bg-white">
                                            <div class="d-flex align-items-center justify-content-between mb-3">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="bi bi-buildings-fill text-danger fs-5"></i>
                                                    <h4 class="h6 fw-bold mb-0 text-dark">Accommodation</h4>
                                                </div>
                                                <span class="badge rounded-pill text-bg-light">@destinationAccommodations.Count</span>
                                            </div>

                                            @if (!destinationAccommodations.Any())
                                            {
                                                <div class="text-center py-4">
                                                    <p class="text-muted mb-3">No accommodation added yet.</p>
                                                    <a asp-controller="Accommodations" asp-action="Create" asp-route-destinationId="@destination.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-primary btn-sm px-4">
                                                        <i class="bi bi-plus-lg me-2"></i> Add Stay
                                                    </a>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="vstack gap-2">
                                                    @foreach (var accommodation in destinationAccommodations.Take(3))
                                                    {
                                                        <div class="border rounded-4 p-3 bg-white itinerary-item-card">
                                                            <div class="d-flex flex-column h-100">
                                                                <div class="flex-grow-1">
                                                                    <div class="fw-semibold text-dark">@accommodation.Name</div>
                                                                    <div class="text-muted small">@accommodation.Type • @accommodation.CheckInDate.ToString("dd MMM") - @accommodation.CheckOutDate.ToString("dd MMM")</div>
                                                                </div>
                                                                <div class="itinerary-item-actions">
                                                                    <a asp-controller="Accommodations" asp-action="Details" asp-route-accommodationType="@accommodation.Type.ToString()" asp-route-accommodationName="@GenerateSlug(accommodation.Name)" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm itinerary-view-btn" title="View Accommodation" aria-label="View Accommodation">
                                                                        <i class="bi bi-eye"></i>
                                                                    </a>
                                                                    <a asp-controller="Accommodations" asp-action="Edit" asp-route-id="@accommodation.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm btn-outline-warning" title="Edit Accommodation">
                                                                        <i class="bi bi-pencil"></i>
                                                                    </a>
                                                                    <a asp-controller="Accommodations" asp-action="Delete" asp-route-id="@accommodation.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm btn-outline-danger" title="Delete Accommodation">
                                                                        <i class="bi bi-trash"></i>
                                                                    </a>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (destinationAccommodations.Count > 3)
                                                    {
                                                        <div class="text-muted small text-center">+ @(destinationAccommodations.Count - 3) more</div>
                                                    }
                                                </div>
                                                <div class="pt-3 mt-3 border-top text-end">
                                                    <a asp-controller="Accommodations" asp-action="Create" asp-route-destinationId="@destination.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-primary btn-sm px-4">
                                                        <i class="bi bi-plus-lg me-2"></i> Add Stay
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <div class="col">
                                        <div class="h-100 border rounded-4 p-4 bg-white">
                                            <div class="d-flex align-items-center justify-content-between mb-3">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="bi bi-send-fill text-danger fs-5"></i>
                                                    <h4 class="h6 fw-bold mb-0 text-dark">Transport</h4>
                                                </div>
                                                <span class="badge rounded-pill text-bg-light">@destinationTransports.Count</span>
                                            </div>

                                            @if (!destinationTransports.Any())
                                            {
                                                <div class="text-center py-4">
                                                    <p class="text-muted mb-3">No transport planned yet.</p>
                                                    <a asp-controller="Transports" asp-action="Create" asp-route-destinationId="@destination.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-primary btn-sm px-4">
                                                        <i class="bi bi-plus-lg me-2"></i> Add Transport
                                                    </a>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="vstack gap-2">
                                                    @foreach (var transport in destinationTransports.Take(3))
                                                    {
                                                        <div class="border rounded-4 p-3 bg-white itinerary-item-card">
                                                            <div class="d-flex flex-column h-100">
                                                                <div class="flex-grow-1">
                                                                    <div class="fw-semibold text-dark">@transport.Type</div>
                                                                    <div class="text-muted small">@transport.DepartureTime.ToString("dd MMM, HH:mm") - @transport.ArrivalTime.ToString("dd MMM, HH:mm")</div>
                                                                </div>
                                                                <div class="itinerary-item-actions">
                                                                    <a asp-controller="Transports" asp-action="Details" asp-route-id="@transport.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm itinerary-view-btn" title="View Transport" aria-label="View Transport">
                                                                        <i class="bi bi-eye"></i>
                                                                    </a>
                                                                    <a asp-controller="Transports" asp-action="Edit" asp-route-id="@transport.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm btn-outline-warning" title="Edit Transport">
                                                                        <i class="bi bi-pencil"></i>
                                                                    </a>
                                                                    <a asp-controller="Transports" asp-action="Delete" asp-route-id="@transport.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm btn-outline-danger" title="Delete Transport">
                                                                        <i class="bi bi-trash"></i>
                                                                    </a>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (destinationTransports.Count > 3)
                                                    {
                                                        <div class="text-muted small text-center">+ @(destinationTransports.Count - 3) more</div>
                                                    }
                                                </div>
                                                <div class="pt-3 mt-3 border-top text-end">
                                                    <a asp-controller="Transports" asp-action="Create" asp-route-destinationId="@destination.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-primary btn-sm px-4">
                                                        <i class="bi bi-plus-lg me-2"></i> Add Transport
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <div class="col">
                                        <div class="h-100 border rounded-4 p-4 bg-white">
                                            <div class="d-flex align-items-center justify-content-between mb-3">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="bi bi-chat-left-text-fill text-danger fs-5"></i>
                                                    <h4 class="h6 fw-bold mb-0 text-dark">Reviews</h4>
                                                </div>
                                                <span class="badge rounded-pill text-bg-light">@destinationReviews.Count</span>
                                            </div>

                                            @if (!destinationReviews.Any())
                                            {
                                                <div class="text-center py-4">
                                                    <p class="text-muted mb-3">No reviews yet.</p>
                                                    <a asp-controller="Reviews" asp-action="Create" asp-route-destinationId="@destination.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-primary btn-sm px-4">
                                                        <i class="bi bi-plus-lg me-2"></i> Add Review
                                                    </a>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="vstack gap-2">
                                                    @foreach (var review in destinationReviews.Take(2))
                                                    {
                                                        <div class="border rounded-4 p-3 bg-white itinerary-item-card">
                                                            <div class="d-flex flex-column h-100">
                                                                <div>
                                                                    <div class="fw-semibold text-dark">@review.Rating / 5</div>
                                                                    <small class="text-muted">@review.User?.FirstName @review.User?.LastName</small>
                                                                    <div class="text-muted small mt-2">@review.Comment</div>
                                                                </div>
                                                                <div class="itinerary-item-actions">
                                                                    <a asp-controller="Reviews" asp-action="Details" asp-route-id="@review.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm itinerary-view-btn" title="View Review" aria-label="View Review">
                                                                        <i class="bi bi-eye"></i>
                                                                    </a>
                                                                    <a asp-controller="Reviews" asp-action="Edit" asp-route-id="@review.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm btn-outline-warning" title="Edit Review">
                                                                        <i class="bi bi-pencil"></i>
                                                                    </a>
                                                                    <a asp-controller="Reviews" asp-action="Delete" asp-route-id="@review.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-sm btn-outline-danger" title="Delete Review">
                                                                        <i class="bi bi-trash"></i>
                                                                    </a>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (destinationReviews.Count > 2)
                                                    {
                                                        <div class="text-muted small text-center">+ @(destinationReviews.Count - 2) more</div>
                                                    }
                                                </div>
                                                <div class="pt-3 mt-3 border-top text-end">
                                                    <a asp-controller="Reviews" asp-action="Create" asp-route-destinationId="@destination.Id" asp-route-returnUrl="@tripReturnUrl" class="btn btn-primary btn-sm px-4">
                                                        <i class="bi bi-plus-lg me-2"></i> Add Review
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="mt-4">
                <div class="row g-3">
                    <div class="col-6 col-lg-3">
                        <div class="border rounded-4 p-3 h-100 text-center bg-white shadow-sm">
                            <div class="text-muted small mb-1">Destinations</div>
                            <div class="fw-bold fs-4">@itineraryCount</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="border rounded-4 p-3 h-100 text-center bg-white shadow-sm">
                            <div class="text-muted small mb-1">Activities</div>
                            <div class="fw-bold fs-4">@activityCount</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="border rounded-4 p-3 h-100 text-center bg-white shadow-sm">
                            <div class="text-muted small mb-1">Accommodation</div>
                            <div class="fw-bold fs-4">@accommodationCount</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="border rounded-4 p-3 h-100 text-center bg-white shadow-sm">
                            <div class="text-muted small mb-1">Transport</div>
                            <div class="fw-bold fs-4">@transportCount</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <div class="border rounded-4 p-3 h-100 text-center bg-white shadow-sm">
                    <div class="text-muted small mb-1">Reviews</div>
                    <div class="fw-bold fs-4">@reviewCount</div>
                </div>
            </div>
        </div>
    </div>
</div>
