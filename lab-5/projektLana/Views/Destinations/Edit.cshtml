@model projektLana.DestinationFormModel
@{
    ViewData["Title"] = "Edit Destination";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0 m-0 fs-5">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-muted text-decoration-none">Destinations</a></li>
            <li class="breadcrumb-item active fw-bold" style="color: var(--travel-primary);" aria-current="page">Edit Destination</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="travel-card card border-0 p-0 overflow-hidden">
                <div class="p-5" style="background: linear-gradient(135deg, var(--travel-secondary), var(--travel-primary)); color: white;">
                    <h2 class="fw-bold mb-2">
                        <i class="bi bi-geo-alt-fill me-3"></i>Update Destination
                    </h2>
                    <p class="mb-0 opacity-90">Update destination details.</p>
                </div>

                <div class="p-5">
                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" id="editDestinationForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                        <input asp-for="Id" type="hidden" />

                        <div class="mb-5 position-relative user-autocomplete" data-autocomplete-url="@Url.Action("Trips", "Destinations")">
                            <label asp-for="TripId" class="form-label fw-bold" style="color: var(--travel-dark);">Trip</label>
                            <input
                                type="text"
                                class="form-control form-control-lg user-autocomplete-input"
                                placeholder="Start typing a trip..."
                                autocomplete="off"
                                value="@Model.TripDisplayName" />
                            <input asp-for="TripId" type="hidden" class="user-autocomplete-value" />
                            <div class="list-group user-autocomplete-results"></div>
                            <span asp-validation-for="TripId" class="text-danger small mt-2 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="City" class="form-label fw-bold" style="color: var(--travel-dark);">City</label>
                            <input asp-for="City" class="form-control form-control-lg" />
                            <span asp-validation-for="City" class="text-danger small mt-2 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Country" class="form-label fw-bold" style="color: var(--travel-dark);">Country</label>
                            <input asp-for="Country" class="form-control form-control-lg" />
                            <span asp-validation-for="Country" class="text-danger small mt-2 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold" style="color: var(--travel-dark);">Description</label>
                            <textarea asp-for="Description" class="form-control form-control-lg" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger small mt-2 d-block"></span>
                        </div>

                        <div class="d-flex gap-3 justify-content-between">
                            <a href="@ViewData["ReturnUrl"]" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-lg" style="background: var(--travel-primary); color: white; border: none;">
                                <i class="bi bi-check-circle-fill me-2"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const form = document.getElementById('editDestinationForm');
            if ($(form).data('validator')) {
                $(form).data('validator').settings.ignore = '';
            }
        });
    </script>
}
